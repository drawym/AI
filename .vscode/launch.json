{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug (J-Link)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "jlink",
            "device": "AT32F435ZMT7",
            "interface": "swd",
            "speed": 4000,
            "executable": "${workspaceFolder}/build/project/AT32F435_LedToggle.elf",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "",
            "runToEntryPoint": "main",
            "postRestartCommands": [
                "monitor reset halt",
                "monitor reset"
            ],
            "showDevDebugOutput": "none",
            "gdbPath": "arm-none-eabi-gdb"
        },
        {
            "name": "Cortex Debug (J-Link) - Attach",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "jlink",
            "device": "AT32F435ZMT7",
            "interface": "swd",
            "speed": 4000,
            "executable": "${workspaceFolder}/build/project/AT32F435_LedToggle.elf",
            "cwd": "${workspaceFolder}",
            "showDevDebugOutput": "none",
            "gdbPath": "arm-none-eabi-gdb"
        }
    ]
}